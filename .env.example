PORT=8787
CLIENT_ORIGIN=http://localhost:5173
VITE_ALLOWED_HOSTS=

# Any OpenAI-compatible /chat/completions service can be used.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=

# Generate all missing explanations in the background when the server starts.
AI_PREGENERATE_ON_START=false
AI_PREGENERATE_CONCURRENCY=1

# Password protection. Leave empty to disable authentication.
# Shared-password multi-user mode: usernames are server-side only, all use AUTH_PASSWORD.
AUTH_SHARED_USERS=
AUTH_PASSWORD=
# Per-user password mode. Example: alice:alice_password,bob:bob_password
AUTH_USERS=
# Secret for signing session cookies. Leave empty to auto-generate (sessions reset on restart).
AUTH_COOKIE_SECRET=
# Session duration in days (default 7).
AUTH_SESSION_DAYS=7
